---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';

const all = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featured = all.filter((p) => p.data.featured);
const shown = (featured.length > 0 ? featured : all).slice(0, 6);
---

<Base>
  <h1>Studio Oswald</h1>
  <p class="lede">
    Selected work and projects. Design, research and things in between.
  </p>

  <h2>Featured work</h2>
  <div class="grid">
    {shown.map((project) => <ProjectCard project={project} />)}
  </div>

  <a class="back" href="/work/">All work →</a>
</Base>
